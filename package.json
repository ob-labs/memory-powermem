{
  "name": "memory-powermem",
  "version": "0.4.0",
  "description": "OpenClaw plugin: long-term memory via PowerMem (default local CLI: npm powermem or pmem on PATH; optional HTTP server; intelligent extraction, Ebbinghaus forgetting curve).",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "scripts",
    "openclaw.plugin.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "postinstall": "node scripts/ensure-native-deps.cjs",
    "native:verify": "node scripts/ensure-native-deps.cjs",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@langchain/openai": "^1.4.1",
    "@mariozechner/pi-ai": "^0.67.2",
    "@sinclair/typebox": "^0.34.0",
    "better-sqlite3": "^12.9.0",
    "powermem": "^0.1.1",
    "sqlite-vec": "^0.1.9"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.1.0"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "repository": "",
  "license": "Apache-2.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "sqlite-vec"
    ]
  }
}
